              }
            ],
            "url": {
              "raw": "{{base_url}}/service-tickets/{{ticket_id}}/assign-mechanic/{{mechanic_id}}",
              "host": ["{{base_url}}"],
              "path": ["service-tickets", "{{ticket_id}}", "assign-mechanic", "{{mechanic_id}}"]
            }
          }
        },
        {
          "name": "Remove Mechanic from Ticket",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
