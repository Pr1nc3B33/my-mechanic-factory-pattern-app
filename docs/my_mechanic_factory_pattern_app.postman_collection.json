              "raw": "{{base_url}}/service-tickets/",
              "host": ["{{base_url}}"],
              "path": ["service-tickets", ""]
            }
          }
        },
        {
          "name": "Assign Mechanic to Ticket",
          "request": {
            "method": "PUT",
