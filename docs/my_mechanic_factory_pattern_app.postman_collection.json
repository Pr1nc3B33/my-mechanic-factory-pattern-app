    },
    {
      "name": "Service Tickets",
      "item": [
        {
          "name": "Create Service Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": {{customer_id}},\n  \"service_date\": \"2026-03-27\",\n  \"service_type\": \"Oil Change\",\n  \"vin\": \"1HGCM82633A123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/service-tickets/",
              "host": ["{{base_url}}"],
              "path": ["service-tickets", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "if (json && json.id) { pm.collectionVariables.set('ticket_id', json.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Service Tickets",
          "request": {
            "method": "GET",
